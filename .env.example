# Copy to .env for local dev (with docker-compose) or paste these into
# Coolify's "Environment Variables" panel when deploying.

# --- Shared secret between Cloudflare Worker and this service ---
ORCHESTRATOR_TOKEN=replace-with-long-random-string

# --- RunPod ---
RUNPOD_ENDPOINT_ID=zeydrhqbkf5dlj
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RUNPOD_MAX_CONCURRENT=20
RUNPOD_TILE_TIMEOUT_SEC=900

# --- Cloudflare R2 (S3-compatible) ---
R2_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET=geotiff-jobs

# --- Pipeline ---
UPSCALE_FACTOR=2
MAX_CONCURRENT_JOBS=2
MAX_TILE_COUNT=500
